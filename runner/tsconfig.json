{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@revhero/qa-shared": ["../shared/src/index.ts"],
      "@revhero/qa-shared/*": ["../shared/src/*"]
    }
  },
  "include": [
    "fixtures/**/*.ts",
    "lib/**/*.ts",
    "tests/**/*.ts",
    "playwright.config.ts",
    "vitest.config.ts",
    "../shared/src/**/*.ts"
  ]
}
