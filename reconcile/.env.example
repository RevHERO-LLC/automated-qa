# Layer 3 reconciliation: env vars consumed by reconcile.sh + check-changelog-coverage.ts.
# Co-located with the audit agent in /home/claude-audit/.env (mode 0600, single shared file).

# GitHub PAT with `repo:read` (private RevHero repos) + `issues:write` (open
# [CHANGELOG-MISSED] issues). Same token used by audit/run-audit.ts.
GH_TOKEN=

# Postgres connection string for the read-only `changelog_reader` role,
# bound to the prod Supabase pooler. SELECT on changelog.changes only.
CHANGELOG_DB_URL=

# Optional Slack webhook for the daily summary ping. Same value as the
# super-admin-portal's SLACK_WEBHOOK_CLAUDE_CHANGES so the channel sees
# both ingestions and missed-log alerts in one place.
SLACK_WEBHOOK_CLAUDE_CHANGES=
