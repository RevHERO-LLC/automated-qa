# Copy to .env for local runs. Never commit .env — it is gitignored.

# --- Staging targets ---
STAGING_BASE_URL=https://staging.revhero.ai
STAGING_BFF_URL=https://user-fe-backend.test.revhero.io

# --- Test accounts (staging only) ---
ADMIN_EMAIL=
ADMIN_PASSWORD=
PAID_ADMIN_EMAIL=
PAID_ADMIN_PASSWORD=
MEMBER_EMAIL=
MEMBER_PASSWORD=
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# --- Database (Supabase pooler, session mode 5432) ---
SUPABASE_POOLER_URL=

# --- Cross-service shared secret ---
INTERNAL_SERVICES_WEBHOOK_SECRET=
ENCRYPTION_KEY=

# --- Toky BYOC (used by runner/fixtures/toky.ts in Phase 2) ---
TOKY_API_KEY=
TOKY_FROM_NUMBER=
TOKY_TO_NUMBER=

# --- GitHub Issues + Slack (used by reporter in Phase 3) ---
GITHUB_TOKEN=
GITHUB_REPO=RevHERO-LLC/automated-qa
SLACK_WEBHOOK_QA=
SLACK_WEBHOOK_DEPLOYS=

# --- Run context ---
QA_REPORT_DIR=./reports
QA_RUN_ID=
QA_TAG_FILTER=
