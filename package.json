    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "build:registry": "tsx scripts/build-registry.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.3"
}
