{
  "name": "@revhero/automated-qa",
  "version": "0.1.0",
  "private": true,
  "description": "RevHero automated QA — Playwright suite + scheduled runner + Claude Code audit agent",
  "scripts": {
    "test": "pnpm -C runner test",
    "test:p0": "pnpm -C runner test:p0",
